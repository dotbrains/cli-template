{
  "language": "python",
  "display_name": "Python",
  "min_version": "3.10",
  "framework": "Click",
  "framework_url": "https://click.palletsprojects.com/",
  "install_cmd": "pip install __PROJECT_NAME__",
  "build_cmd": "python -m build",
  "test_cmd": "pytest --cov=__PROJECT_NAME__ --cov-report=term-missing --cov-fail-under=80",
  "lint_cmd": "ruff check src/ tests/ && ruff format --check src/ tests/",
  "clean_cmd": "rm -rf .venv dist/ build/ *.egg-info .pytest_cache .mypy_cache .ruff_cache",
  "deps_url": "https://python.org/",
  "badges": ["Python", "Click"],
  "badge_color": "3776AB",
  "badge_logo": "python",
  "github_release_pattern": "__PROJECT_NAME__-*-py3-none-any.whl",
  "github_release_extract": "pip install /tmp/__PROJECT_NAME__-*-py3-none-any.whl",
  "binary_name": "__PROJECT_NAME__",
  "src_dir": "src/__PROJECT_NAME__",
  "entry_point": "src/__PROJECT_NAME__/cli.py"
}
